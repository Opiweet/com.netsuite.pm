<restlet scriptid="customscript_bc_pm_rst_api">
  <description>Handle Project Management Server Logics</description>
  <isinactive>F</isinactive>
  <name>BC_PM_RST_API</name>
  <notifyadmins>F</notifyadmins>
  <notifyemails></notifyemails>
  <notifyowner>T</notifyowner>
  <notifyuser>F</notifyuser>
  <scriptfile>[/SuiteApps/com.netsuite.pm/BC_PM_RST_API.js]</scriptfile>
  <scriptcustomfields>
    <scriptcustomfield scriptid="custscript_pm_shared_secret">
      <accesslevel>2</accesslevel>
      <applyformatting>F</applyformatting>
      <checkspelling>F</checkspelling>
      <defaultchecked>F</defaultchecked>
      <defaultselection></defaultselection>
      <defaultvalue></defaultvalue>
      <description>A shared secret ID used to validate middleware&apos;s requests. Ensure the same secret is store in middleware env.</description>
      <displayheight></displayheight>
      <displaytype>NORMAL</displaytype>
      <displaywidth></displaywidth>
      <dynamicdefault></dynamicdefault>
      <fieldtype>TEXT</fieldtype>
      <help>A shared secret ID used to validate middleware&apos;s requests. Ensure the same secret is store in middleware env.</help>
      <isformula>F</isformula>
      <ismandatory>F</ismandatory>
      <label>Shared Secret ID</label>
      <linktext></linktext>
      <maxlength></maxlength>
      <maxvalue></maxvalue>
      <minvalue></minvalue>
      <onparentdelete></onparentdelete>
      <searchlevel>2</searchlevel>
      <selectrecordtype></selectrecordtype>
      <setting></setting>
      <storevalue>T</storevalue>
    </scriptcustomfield>
    <scriptcustomfield scriptid="custscript_pm_enable_writes">
      <accesslevel>2</accesslevel>
      <applyformatting>F</applyformatting>
      <checkspelling>F</checkspelling>
      <defaultchecked>T</defaultchecked>
      <defaultselection></defaultselection>
      <defaultvalue></defaultvalue>
      <description>Enable or disable write operations in the RESTlet.</description>
      <displayheight></displayheight>
      <displaytype>NORMAL</displaytype>
      <displaywidth></displaywidth>
      <dynamicdefault></dynamicdefault>
      <fieldtype>CHECKBOX</fieldtype>
      <help>When unchecked, write actions are blocked while read actions continue.</help>
      <isformula>F</isformula>
      <ismandatory>F</ismandatory>
      <label>Enable Writes</label>
      <linktext></linktext>
      <maxlength></maxlength>
      <maxvalue></maxvalue>
      <minvalue></minvalue>
      <onparentdelete></onparentdelete>
      <searchlevel>2</searchlevel>
      <selectrecordtype></selectrecordtype>
      <setting></setting>
      <storevalue>T</storevalue>
    </scriptcustomfield>
  </scriptcustomfields>
  <scriptdeployments>
    <scriptdeployment scriptid="customdeploy_bc_pm_rst_api">
      <allemployees>F</allemployees>
      <allpartners>F</allpartners>
      <allroles>T</allroles>
      <audslctrole></audslctrole>
      <custscript_pm_enable_writes>T</custscript_pm_enable_writes>
      <custscript_pm_shared_secret></custscript_pm_shared_secret>
      <isdeployed>T</isdeployed>
      <loglevel>ERROR</loglevel>
      <status>RELEASED</status>
      <title>BC_PM_RST_API</title>
    </scriptdeployment>
  </scriptdeployments>
</restlet>
